# =================================================================
# NBA Probability Model - Streamlit secrets template
# =================================================================
# Copy this file to `.streamlit/secrets.toml` and fill in real values.
# Do NOT commit secrets.toml. It's in .gitignore.
#
# On Streamlit Community Cloud, paste the same TOML into:
#   App settings -> Secrets

# -----------------------------------------------------------------
# OIDC login (Streamlit native, requires streamlit >= 1.42)
# -----------------------------------------------------------------
[auth]
# Public URL Streamlit will redirect back to after the OIDC dance.
# On Streamlit Community Cloud this is usually:
#   https://<your-app-id>.streamlit.app/oauth2callback
redirect_uri  = "https://example.streamlit.app/oauth2callback"
# Random 32+ character string. Keep it stable across deploys.
cookie_secret = "change-me-to-a-32-char-random-string"
# Optional: emails listed here are forced to premium tier without paying.
# Useful for the project owner / dev account.
admins = [
    "you@example.com",
]

# Google OAuth credentials from
# https://console.cloud.google.com/apis/credentials
[auth.google]
client_id     = "GOOGLE_CLIENT_ID.apps.googleusercontent.com"
client_secret = "GOCSPX-..."
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# Microsoft OAuth credentials from
# https://portal.azure.com -> App registrations
[auth.microsoft]
client_id     = "MICROSOFT_CLIENT_ID"
client_secret = "MICROSOFT_CLIENT_SECRET"
# Common = personal + work + school accounts. Use your tenant id for a
# single-tenant app.
server_metadata_url = "https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration"


# -----------------------------------------------------------------
# Stripe membership / billing
# -----------------------------------------------------------------
[stripe]
# EITHER set a single Payment Link URL (simplest path - one pre-built
# Stripe Payment Link the app reuses for every upgrade click)...
payment_link_url = "https://buy.stripe.com/test_xxxxxxxxxxxxxxxxxx"
# ...OR set secret_key + price_id and the app will create a Checkout
# Session at click time.  Leave payment_link_url empty in that case.
# secret_key  = "sk_test_..."
# price_id    = "price_..."
# success_url = "https://example.streamlit.app/?success=1"
# cancel_url  = "https://example.streamlit.app/?cancelled=1"

# Required for the FastAPI webhook handler to verify Stripe signatures.
# Get this from the Stripe dashboard after creating the webhook endpoint.
webhook_secret = "whsec_..."
